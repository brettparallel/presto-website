---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = await getEntry('reveal', 'the-reveal');
const d = page.data;

const navLinks = [
  { label: 'How it works', href: '/#how-it-works' },
  { label: "What's included", href: '/#whats-included' },
  { label: 'Pricing', href: '/#pricing' },
  { label: 'FAQ', href: '/#faq' },
];

const footerColumns = [
  {
    heading: 'Product',
    links: [
      { label: 'How it works', href: '/#how-it-works' },
      { label: "What's included", href: '/#whats-included' },
      { label: 'Pricing', href: '/#pricing' },
      { label: 'FAQ', href: '/#faq' },
    ],
  },
  {
    heading: 'Socials',
    links: [
      { label: 'Facebook', href: 'https://www.facebook.com/heyprestodesign/' },
      { label: 'X', href: 'https://x.com/heyprestodesgn' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/company/heyprestodesign/' },
      { label: 'Instagram', href: 'https://www.instagram.com/heyprestodesgn' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Terms & Conditions', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Pause / Cancel', href: "mailto:hello@heypresto.design?subject=I'd%20like%20to%20pause%2Fcancel%2C%20effective%20at%20my%20next%20billing%20after%2030%20days" },
    ],
  },
];

const reportFile = '/assets/reports/the-reveal-issue-01-2026-q3.pdf';
---

<Base title={d.seo.title} description={d.seo.description}>
  <Header navLinks={navLinks} ctaLabel="Get started" ctaHref="/#pricing" />

  <main>
    <section class="hero" id="reveal-hero" aria-labelledby="reveal-headline">
      <img class="hero-burst" src="/assets/burst-cluster-purple.png" alt="" aria-hidden="true"
        style="left:6%;top:70px;width:170px;height:170px;opacity:.85;">
      <img class="hero-burst" src="/assets/burst-white.png" alt="" aria-hidden="true"
        style="right:12%;top:48px;width:70px;height:70px;opacity:.9;">
      <img class="hero-burst" src="/assets/burst-cluster-purple.png" alt="" aria-hidden="true"
        style="right:4%;bottom:80px;width:120px;height:120px;opacity:.8;">

      <div class="wrap">
        <div class="hero-badge reveal">
          <span class="dot" aria-hidden="true"></span>
          {d.hero.badge}
        </div>
        <h1 class="hero-headline reveal-headline-display reveal reveal-delay-1" id="reveal-headline">
          <span style="color:#fff">{d.hero.headlineLine1}</span> <span style="color:var(--lime-500)">{d.hero.headlineLine2}</span>
        </h1>
        <p class="hero-sub reveal reveal-delay-2">{d.hero.subline}</p>
        <div class="hero-actions reveal reveal-delay-3">
          <a href="#get-the-report" class="btn btn--lime btn--lg">
            {d.hero.ctaLabel}
            <span class="btn-arrow" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <div class="trust-bar">
      <div class="wrap">
        <img src="/assets/burst-navy.png" alt="" aria-hidden="true" width="26" height="26">
        {d.banner.text}
      </div>
    </div>

    <section class="highlights" id="highlights" aria-labelledby="highlights-heading">
      <div class="wrap">
        <div class="highlights-header">
          <span class="eyebrow reveal"><span class="dot" aria-hidden="true"></span>{d.highlights.eyebrow}</span>
          <h2 class="t-h2 reveal-heading-bold reveal reveal-delay-1" id="highlights-heading">{d.highlights.heading}</h2>
        </div>

        <div class="highlights-grid">
          {d.highlights.items.map((item, i) => (
            <div class={`highlight-card highlight-card--${item.variant} reveal`} style={`transition-delay:${(i + 2) * 0.1}s`}>
              <div class="highlight-num">{item.num}</div>
              <h3 class="highlight-title">{item.title}</h3>
              <p class="highlight-desc">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="get-report" id="get-the-report" aria-labelledby="get-report-heading">
      <img class="report-burst" src="/assets/burst-cluster-purple.png" alt="" aria-hidden="true">
      <div class="wrap">
        <div class="report-card reveal">
          <div class="report-card-copy">
            <span class="eyebrow eyebrow--dark"><span class="dot" aria-hidden="true"></span>{d.form.eyebrow}</span>
            <h2 class="t-h2 reveal-heading-bold" id="get-report-heading" style="color:#fff;margin-top:14px;">{d.form.heading}</h2>
            <p class="report-trust">{d.form.trustLine}</p>
          </div>

          <div class="report-card-form">
            <form id="reveal-form" novalidate>
              <label for="reveal-email" class="report-form-label">{d.form.emailLabel}</label>
              <div class="report-form-row">
                <input type="email" id="reveal-email" name="EMAIL" class="report-form-input" placeholder="you@company.com" required>
                <button type="submit" id="reveal-submit" class="btn btn--lime btn--md">
                  {d.form.buttonLabel}
                </button>
              </div>
              <p id="reveal-form-state" class="report-form-state" role="status" aria-live="polite"></p>
              <p class="report-form-note">{d.footerNote}</p>
            </form>

            <div id="reveal-form-success" class="report-success" hidden>
              <h3>{d.form.successHeading}</h3>
              <p>{d.form.successText}</p>
              <a id="reveal-download-link" href={reportFile} download class="btn btn--white btn--md">
                {d.form.downloadLabel}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer
    tagline="Your brand's monthly creative partner. Design, WordPress, and direction — async, no lock-in."
    copyright="© 2026 Presto. Australia-based, globally trusted."
    columns={footerColumns}
  />
</Base>

<script define:vars={{ reportFile }}>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  const MC_ACTION = 'https://intwo.us17.list-manage.com/subscribe/post-json?u=82d53be69cbad7266b3022af9&id=258e03c3c7&f_id=0007cce3f0';
  const MC_TAG_ID = '8336481';
  const MC_BOT_FIELD = 'b_82d53be69cbad7266b3022af9_258e03c3c7';

  function subscribeToMailchimp(email) {
    return new Promise(resolve => {
      const callbackName = 'mcCallback' + Date.now();
      let script;
      const timer = setTimeout(() => {
        cleanup();
        resolve({ result: 'timeout' });
      }, 8000);
      function cleanup() {
        clearTimeout(timer);
        delete window[callbackName];
        script?.remove();
      }
      window[callbackName] = data => {
        cleanup();
        resolve(data);
      };
      const params = new URLSearchParams({ EMAIL: email, tags: MC_TAG_ID, c: callbackName });
      params.set(MC_BOT_FIELD, '');
      script = document.createElement('script');
      script.src = `${MC_ACTION}&${params.toString()}`;
      script.onerror = () => {
        cleanup();
        resolve({ result: 'network-error' });
      };
      document.body.appendChild(script);
    });
  }

  const form = document.getElementById('reveal-form');
  const emailInput = document.getElementById('reveal-email');
  const submitBtn = document.getElementById('reveal-submit');
  const stateEl = document.getElementById('reveal-form-state');
  const successEl = document.getElementById('reveal-form-success');
  const downloadLink = document.getElementById('reveal-download-link');

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    const originalLabel = submitBtn.textContent;
    submitBtn.textContent = 'Sending…';
    stateEl.textContent = '';
    stateEl.classList.remove('is-error');

    const data = await subscribeToMailchimp(email);

    if (data.result === 'network-error' || data.result === 'timeout') {
      stateEl.classList.add('is-error');
      stateEl.textContent = "Couldn't reach our list just now — try again, or email hello@heypresto.design and we'll send it straight over.";
      submitBtn.disabled = false;
      submitBtn.textContent = originalLabel;
      return;
    }

    form.hidden = true;
    successEl.hidden = false;
    downloadLink.href = reportFile;
  });
</script>

<style>
  /* Scoped to this page — a bolder, larger take on the shared hero/heading styles */
  .reveal-headline-display {
    font-weight: 800;
    font-size: clamp(40px, 9vw, 168px);
    line-height: 0.92;
    letter-spacing: -0.02em;
    max-width: none;
    white-space: nowrap;
  }
  .reveal-heading-bold { font-weight: 800; }

  .highlights { padding: 100px 0; }
  .highlights-header { text-align: center; max-width: 640px; margin: 0 auto 56px; }
  .highlights-header h2 { margin-top: 18px; }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    max-width: 1080px;
    margin: 0 auto;
  }

  .highlight-card {
    border-radius: var(--radius-2xl);
    padding: 36px 32px 40px;
    position: relative;
    overflow: hidden;
  }
  .highlight-card--lime { background: var(--lime-500); color: var(--navy-800); }
  .highlight-card--navy { background: var(--navy-800); color: #fff; border: 1px solid rgba(255,255,255,.12); }
  .highlight-card--outline { background: transparent; border: 1px solid var(--border); }

  .highlight-num {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 20px;
  }
  .highlight-card--lime .highlight-num { opacity: .85; }
  .highlight-card--navy .highlight-num { opacity: .45; }
  .highlight-card--outline .highlight-num { color: var(--navy-800); opacity: .18; }

  .highlight-title { font-size: 21px; font-weight: 800; letter-spacing: -.02em; margin: 0 0 12px; }
  .highlight-card--outline .highlight-title { color: var(--navy-800); }

  .highlight-desc { font-size: 15.5px; line-height: 1.55; margin: 0; font-weight: 500; }
  .highlight-card--lime .highlight-desc { color: var(--navy-700); }
  .highlight-card--navy .highlight-desc { color: rgba(255,255,255,.72); }
  .highlight-card--outline .highlight-desc { color: var(--fg-2); }

  /* ── Get the report ── */
  .get-report {
    background: var(--navy-800);
    position: relative;
    overflow: hidden;
    padding: 100px 0;
  }
  .report-burst {
    position: absolute;
    pointer-events: none;
    object-fit: contain;
    left: -60px;
    bottom: -60px;
    width: 260px;
    height: 260px;
    opacity: .35;
  }
  .report-card {
    position: relative;
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .report-trust {
    font-size: 15.5px;
    color: rgba(255,255,255,.68);
    margin: 14px 0 0;
    max-width: none;
    line-height: 1.5;
  }

  .report-card-form {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.14);
    border-radius: var(--radius-xl);
    padding: 32px;
  }
  .report-form-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,.68);
    margin-bottom: 10px;
  }
  .report-form-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .report-form-input {
    flex: 1 1 220px;
    min-width: 0;
    padding: 14px 16px;
    border-radius: var(--radius-pill);
    border: 1.5px solid rgba(255,255,255,.2);
    background: rgba(255,255,255,.06);
    color: #fff;
    font-size: 15.5px;
    font-family: var(--font-sans);
  }
  .report-form-input::placeholder { color: rgba(255,255,255,.4); }
  .report-form-input:focus { outline: 2px solid var(--lime-500); outline-offset: 2px; }
  .report-form-state {
    margin: 14px 0 0;
    font-size: 14px;
    color: rgba(255,255,255,.6);
    min-height: 1em;
  }
  .report-form-state.is-error { color: #FFB4B4; }
  .report-form-note {
    margin: 10px 0 0;
    font-size: 12.5px;
    color: rgba(255,255,255,.4);
  }

  .report-success h3 {
    font-family: var(--font-display);
    font-weight: 800;
    color: #fff;
    font-size: 26px;
    margin: 0 0 10px;
  }
  .report-success p {
    color: rgba(255,255,255,.72);
    font-size: 15.5px;
    line-height: 1.55;
    margin: 0 0 20px;
  }

  @media (max-width: 760px) {
    .get-report { padding: 72px 0; }
    .report-card { grid-template-columns: 1fr; gap: 32px; }
    .highlights { padding: 72px 0; }
  }
</style>

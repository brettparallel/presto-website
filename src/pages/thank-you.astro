---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = await getEntry('thankYou', 'thank-you');
const d = page.data;

const navLinks = [
  { label: 'How it works', href: '/#how-it-works' },
  { label: "What's included", href: '/#whats-included' },
  { label: 'Pricing', href: '/#pricing' },
  { label: 'FAQ', href: '/#faq' },
];

const footerColumns = [
  {
    heading: 'Product',
    links: [
      { label: 'How it works', href: '/#how-it-works' },
      { label: "What's included", href: '/#whats-included' },
      { label: 'Pricing', href: '/#pricing' },
      { label: 'FAQ', href: '/#faq' },
    ],
  },
  {
    heading: 'Socials',
    links: [
      { label: 'Facebook', href: 'https://www.facebook.com/heyprestodesign/' },
      { label: 'X', href: 'https://x.com/heyprestodesgn' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/company/heyprestodesign/' },
      { label: 'Instagram', href: 'https://www.instagram.com/heyprestodesgn' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Terms & Conditions', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Pause / Cancel', href: "mailto:hello@heypresto.design?subject=I'd%20like%20to%20pause%2Fcancel%2C%20effective%20at%20my%20next%20billing%20after%2030%20days" },
    ],
  },
];
---

<Base title={d.seo.title} description={d.seo.description}>
  <Header navLinks={navLinks} ctaLabel="Get started" ctaHref="/#pricing" />

  <main>
    <section class="hero" id="thank-you-hero" aria-labelledby="thank-you-headline">
      <img class="hero-burst" src="/assets/burst-cluster-purple.png" alt="" aria-hidden="true"
        style="left:6%;top:70px;width:170px;height:170px;opacity:.85;">
      <img class="hero-burst" src="/assets/burst-white.png" alt="" aria-hidden="true"
        style="right:12%;top:48px;width:70px;height:70px;opacity:.9;">
      <img class="hero-burst" src="/assets/burst-cluster-purple.png" alt="" aria-hidden="true"
        style="right:4%;bottom:80px;width:120px;height:120px;opacity:.8;">

      <div class="wrap">
        <div class="hero-badge reveal">
          <span class="dot" aria-hidden="true"></span>
          {d.hero.badge}
        </div>
        <h1 class="hero-headline reveal reveal-delay-1" id="thank-you-headline">
          <span style="color:#fff">{d.hero.headlineLine1}</span><br>
          <span style="color:var(--lime-500)">{d.hero.headlineLine2}</span>
        </h1>
        <p class="hero-sub reveal reveal-delay-2">{d.hero.subline}</p>
      </div>
    </section>

    <div class="trust-bar">
      <div class="wrap">
        <img src="/assets/burst-navy.png" alt="" aria-hidden="true" width="26" height="26">
        {d.banner.text}
      </div>
    </div>

    <section class="next-steps" id="next-steps" aria-labelledby="next-steps-heading">
      <div class="wrap">
        <div class="next-steps-header">
          <span class="eyebrow reveal"><span class="dot" aria-hidden="true"></span>{d.nextSteps.eyebrow}</span>
          <h2 class="t-h2 reveal reveal-delay-1" id="next-steps-heading">{d.nextSteps.heading}</h2>
        </div>

        <div class="next-steps-grid">
          {d.nextSteps.steps.map((step, i) => (
            <div class={`next-step-card next-step-card--${step.variant} reveal`} style={`transition-delay:${(i + 2) * 0.1}s`}>
              <div class="next-step-num">{step.num}</div>
              <h3 class="next-step-title">{step.title}</h3>
              <p class="next-step-desc">{step.description}</p>
            </div>
          ))}
        </div>

        <div class="next-steps-cta reveal reveal-delay-3">
          <div>
            <p class="next-steps-cta-label">{d.cta.label}</p>
            <p class="next-steps-cta-text" set:html={d.cta.text.replace('hello@heypresto.design', '<a href="mailto:hello@heypresto.design">hello@heypresto.design</a>')} />
          </div>
          <a href={d.cta.buttonHref} class="btn btn--primary btn--md">
            {d.cta.buttonLabel}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer
    tagline="Your brand's monthly creative partner. Design, WordPress, and direction — async, no lock-in."
    copyright="© 2026 Presto. Australia-based, globally trusted."
    columns={footerColumns}
  />
</Base>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
  .next-steps { padding: 100px 0; }
  .next-steps-header { text-align: center; max-width: 640px; margin: 0 auto 56px; }
  .next-steps-header h2 { margin-top: 18px; }

  .next-steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    max-width: 960px;
    margin: 0 auto;
  }

  .next-step-card {
    border-radius: var(--radius-2xl);
    padding: 36px 32px 40px;
    position: relative;
    overflow: hidden;
  }
  .next-step-card--lime { background: var(--lime-500); color: var(--navy-800); }
  .next-step-card--navy { background: var(--navy-800); color: #fff; border: 1px solid rgba(255,255,255,.12); }
  .next-step-card--outline { background: transparent; border: 1px solid var(--border); }

  .next-step-num {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 20px;
  }
  .next-step-card--lime .next-step-num { opacity: .85; }
  .next-step-card--navy .next-step-num { opacity: .45; }
  .next-step-card--outline .next-step-num { color: var(--navy-800); opacity: .18; }

  .next-step-title { font-size: 22px; font-weight: 800; letter-spacing: -.02em; margin: 0 0 12px; }
  .next-step-card--outline .next-step-title { color: var(--navy-800); }

  .next-step-desc { font-size: 15.5px; line-height: 1.55; margin: 0; font-weight: 500; }
  .next-step-card--lime .next-step-desc { color: var(--navy-700); }
  .next-step-card--navy .next-step-desc { color: rgba(255,255,255,.72); }
  .next-step-card--outline .next-step-desc { color: var(--fg-2); }

  .next-steps-cta {
    margin-top: 32px;
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
    background: var(--navy-50);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 32px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .next-steps-cta-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--purple-500);
    margin: 0 0 8px;
  }
  .next-steps-cta-text {
    font-size: 16px;
    color: var(--fg-1);
    font-weight: 500;
    line-height: 1.5;
    max-width: 440px;
    margin: 0;
  }
  .next-steps-cta-text :global(a) {
    color: var(--purple-500);
    text-decoration: none;
    font-weight: 600;
  }
  .next-steps-cta-text :global(a:hover) { text-decoration: underline; }

  @media (max-width: 600px) {
    .next-steps { padding: 72px 0; }
    .next-steps-cta { padding: 28px; }
  }
</style>

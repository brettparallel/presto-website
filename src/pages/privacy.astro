---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const navLinks = [
  { label: 'How it works', href: '/#how-it-works' },
  { label: "What's included", href: '/#whats-included' },
  { label: 'Pricing', href: '/#pricing' },
  { label: 'FAQ', href: '/#faq' },
];

const footerColumns = [
  {
    heading: 'Product',
    links: [
      { label: 'How it works', href: '/#how-it-works' },
      { label: "What's included", href: '/#whats-included' },
      { label: 'Pricing', href: '/#pricing' },
      { label: 'FAQ', href: '/#faq' },
    ],
  },
  {
    heading: 'Socials',
    links: [
      { label: 'Facebook', href: 'https://www.facebook.com/heyprestodesign/' },
      { label: 'X', href: 'https://x.com/heyprestodesgn' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/company/heyprestodesign/' },
      { label: 'Instagram', href: 'https://www.instagram.com/heyprestodesgn' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Terms & Conditions', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Pause / Cancel', href: "mailto:hello@heypresto.design?subject=I'd%20like%20to%20pause%2Fcancel%2C%20effective%20at%20my%20next%20billing%20after%2030%20days" },
    ],
  },
];
---

<Base
  title="Privacy Policy — Presto"
  description="Privacy Policy explaining how Presto collects, uses, and safeguards your personal information."
>
  <Header navLinks={navLinks} ctaLabel="Get started" ctaHref="/#pricing" />

  <main class="legal-page">
    <div class="legal-wrap">
      <header class="legal-header">
        <h1>Privacy Policy</h1>
        <p class="legal-meta">Effective date: June 2026</p>
      </header>

      <div class="legal-body">

        <h2>Introduction</h2>
        <p>Welcome to Presto.</p>
        <p>Presto ("we", "us", "our") operates <a href="/">https://heypresto.design</a> (the "Service"). This Privacy Policy explains how we collect, use, safeguard, and disclose information that results from your use of our Service.</p>
        <p>We use your data to provide and improve the Service. By using the Service, you agree to the collection and use of information in accordance with this Policy. Unless otherwise defined in this Privacy Policy, terms have the same meaning as in our <a href="/terms">Terms and Conditions</a>.</p>
        <p>Our Terms and Conditions ("Terms") govern all use of the Service and, together with this Privacy Policy, constitute your agreement with us.</p>
        <p>Presto is based in Australia and handles personal information in accordance with the <em>Privacy Act 1988</em> (Cth) and the Australian Privacy Principles (APPs). Where we serve clients in the European Union or California, we also acknowledge rights under the GDPR and CCPA respectively.</p>

        <h2>Definitions</h2>
        <p><strong>SERVICE</strong> means <a href="/">https://heypresto.design</a>, operated by Presto.</p>
        <p><strong>PERSONAL DATA</strong> means data about a living individual who can be identified from those data (or from those data in combination with other information we hold).</p>
        <p><strong>USAGE DATA</strong> is data collected automatically — either generated by use of the Service or from the Service infrastructure itself (for example, the duration of a page visit).</p>
        <p><strong>COOKIES</strong> are small files stored on your device (computer or mobile device).</p>
        <p><strong>DATA CONTROLLER</strong> means the person or entity that determines the purposes and means of processing personal data. For the purposes of this Privacy Policy, Presto is the Data Controller of your personal data.</p>
        <p><strong>SERVICE PROVIDERS</strong> means third-party companies or individuals who process data on Presto's behalf.</p>

        <h2>Information We Collect and Use</h2>
        <p>We collect several types of information for the purposes of providing and improving our Service.</p>
        <h3>Personal Data</h3>
        <p>When you contact us, book a discovery call, or subscribe to the Service, we may ask you to provide personally identifiable information, including:</p>
        <ul>
          <li>Name and email address</li>
          <li>Business name and contact details</li>
          <li>Project information and creative assets you share with us</li>
        </ul>
        <p>We may use this information to contact you with relevant communications about the Service. You may opt out of marketing communications at any time by emailing <a href="mailto:hello@heypresto.design">hello@heypresto.design</a> or following the unsubscribe link in any email.</p>
        <h3>Usage Data</h3>
        <p>When you visit the Website, we may collect information your browser sends automatically ("Usage Data"), including:</p>
        <ul>
          <li>IP address</li>
          <li>Browser type and version</li>
          <li>Pages visited and time spent on each page</li>
          <li>Date and time of your visit</li>
          <li>Unique device identifiers and other diagnostic data</li>
        </ul>
        <p>When you access the Service via a mobile device, Usage Data may also include your mobile device type, operating system, mobile browser type, and unique device ID.</p>

        <h2>Cookies and Tracking Technologies</h2>
        <p>We use cookies and similar tracking technologies to monitor activity on our Service and retain certain information.</p>
        <p>Cookies are small files with a unique identifier sent to your browser from a website and stored on your device. We also use beacons and scripts to collect and track information and to improve and analyse our Service.</p>
        <p>You may instruct your browser to refuse all cookies or to notify you when a cookie is being sent. Note that some parts of the Service may not function correctly if cookies are disabled.</p>
        <p>We use the following types of cookies:</p>
        <ul>
          <li><strong>Session Cookies:</strong> to operate the Service</li>
          <li><strong>Preference Cookies:</strong> to remember your settings and preferences</li>
          <li><strong>Security Cookies:</strong> for security and fraud prevention</li>
          <li><strong>Analytics Cookies:</strong> to understand how visitors use the Website</li>
        </ul>

        <h2>How We Use Your Data</h2>
        <p>Presto uses collected data for the following purposes:</p>
        <ul>
          <li>To provide and maintain the Service</li>
          <li>To process subscription payments and fulfil our obligations to you</li>
          <li>To notify you about changes to the Service or your subscription</li>
          <li>To communicate with you about your active requests and project board</li>
          <li>To provide customer support</li>
          <li>To gather analysis and insight to improve the Service</li>
          <li>To monitor Website usage</li>
          <li>To detect, prevent, and address technical issues</li>
          <li>To send you relevant news, updates, or promotional information about Presto (you may opt out at any time)</li>
          <li>To comply with legal obligations</li>
        </ul>
        <p>We do not sell your personal data to third parties.</p>

        <h2>Retention of Data</h2>
        <p>We retain your Personal Data for as long as necessary to fulfil the purposes set out in this Policy, and as required to comply with our legal obligations, resolve disputes, and enforce our agreements.</p>
        <p>Usage Data is generally retained for a shorter period, unless it is being used to improve Service functionality or security, or we are legally required to retain it longer.</p>

        <h2>Transfer of Data</h2>
        <p>Presto is based in Australia. Your personal data may be processed on computers or servers located in other countries — including via third-party service providers operating in the United States or elsewhere — where data protection laws may differ from those in your jurisdiction.</p>
        <p>By using the Service, you consent to such transfer. We take reasonable steps to ensure your data is handled securely and in accordance with this Privacy Policy regardless of where it is processed.</p>

        <h2>Disclosure of Data</h2>
        <p>We may disclose your personal data in the following circumstances:</p>
        <p><strong>Legal requirements:</strong> Where required to do so by law, or in response to valid requests from public authorities (e.g. a court or government agency).</p>
        <p><strong>Business transactions:</strong> If Presto is involved in a merger, acquisition, or sale of assets, your Personal Data may be transferred. We will provide notice before such transfer and any change in privacy treatment.</p>
        <p><strong>Service Providers:</strong> We share data with third-party companies who assist us in operating the Service, processing payments, or analysing how the Service is used. These parties have access to your Personal Data only to perform tasks on our behalf and are obligated not to disclose or use it for any other purpose.</p>
        <p><strong>With your consent:</strong> In any other circumstance where you have explicitly consented.</p>

        <h2>Service Providers</h2>
        <p>We currently use the following third-party Service Providers who may have access to your Personal Data:</p>
        <p><strong>Stripe</strong> — Payment processing<br>
        Privacy Policy: <a href="https://stripe.com/privacy" target="_blank" rel="noopener noreferrer">https://stripe.com/privacy</a><br>
        We do not store your card details. Payment information is submitted directly to and processed by Stripe.</p>
        <p><strong>Google Analytics</strong> — Website analytics<br>
        Privacy Policy: <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">https://policies.google.com/privacy</a><br>
        Google Analytics tracks and reports Website traffic. You can opt out of Google Analytics tracking by installing the Google Analytics Opt-out Browser Add-on: <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer">https://tools.google.com/dlpage/gaoptout</a></p>

        <h2>Security of Data</h2>
        <p>The security of your Personal Data is important to us. We use commercially reasonable measures to protect it. However, no method of transmission over the internet or electronic storage is completely secure, and we cannot guarantee absolute security.</p>

        <h2>Your Rights — Australia (Privacy Act 1988)</h2>
        <p>Under the Australian Privacy Act 1988 (Cth) and Australian Privacy Principles, you have the right to:</p>
        <ul>
          <li>Request access to the personal information Presto holds about you</li>
          <li>Request correction of personal information that is inaccurate, incomplete, or out of date</li>
          <li>Lodge a complaint with the Office of the Australian Information Commissioner (OAIC) if you believe we have mishandled your personal information: <a href="https://www.oaic.gov.au" target="_blank" rel="noopener noreferrer">https://www.oaic.gov.au</a></li>
        </ul>
        <p>To make a request, contact us at <a href="mailto:hello@heypresto.design">hello@heypresto.design</a>.</p>

        <h2>Your Rights — European Union and EEA (GDPR)</h2>
        <p>If you are a resident of the European Union or European Economic Area, you have the following rights under the General Data Protection Regulation (GDPR):</p>
        <ul>
          <li><strong>Right to access:</strong> to obtain confirmation of whether we process your personal data, and to receive a copy of it</li>
          <li><strong>Right to rectification:</strong> to have inaccurate or incomplete personal data corrected</li>
          <li><strong>Right to erasure:</strong> to request deletion of your personal data under certain conditions</li>
          <li><strong>Right to restrict processing:</strong> to request that we limit how we use your personal data</li>
          <li><strong>Right to data portability:</strong> to receive your personal data in a structured, commonly used, machine-readable format</li>
          <li><strong>Right to object:</strong> to object to processing of your personal data for direct marketing or based on our legitimate interests</li>
          <li><strong>Right to withdraw consent:</strong> where processing is based on consent, to withdraw that consent at any time without affecting the lawfulness of prior processing</li>
        </ul>
        <p>To exercise any of these rights, email us at <a href="mailto:hello@heypresto.design">hello@heypresto.design</a>. We may ask you to verify your identity before responding. You also have the right to lodge a complaint with your local data protection authority in the EEA.</p>

        <h2>Your Rights — California Residents (CCPA)</h2>
        <p>If you are a California resident, you are entitled under the California Consumer Privacy Act (CCPA) to:</p>
        <ul>
          <li><strong>Know</strong> what personal information we collect about you, including the categories of information, the sources it came from, the purpose for collecting it, and the third parties it may be shared with</li>
          <li><strong>Delete</strong> your personal information (subject to certain exceptions)</li>
          <li><strong>Opt out of sale</strong> of your personal information — note that Presto does not sell personal information to third parties</li>
          <li><strong>Non-discrimination</strong> for exercising your CCPA rights</li>
        </ul>
        <p>To exercise your California privacy rights, contact us at <a href="mailto:hello@heypresto.design">hello@heypresto.design</a>. We will respond to verifiable requests within 45 days.</p>

        <h2>Do Not Track</h2>
        <p>We honour Do Not Track (DNT) signals where technically feasible. Do Not Track is a preference you can set in your web browser to inform websites that you do not want to be tracked. You can enable or disable Do Not Track in your browser's Preferences or Settings.</p>

        <h2>Children's Privacy</h2>
        <p>The Service is not directed at individuals under the age of 16. We do not knowingly collect Personal Data from children. If you are aware that a child has provided us with personal information without parental consent, please contact us at <a href="mailto:hello@heypresto.design">hello@heypresto.design</a>. If we become aware that we have collected Personal Data from a child without appropriate consent, we will take steps to delete that information promptly.</p>

        <h2>Links to Other Sites</h2>
        <p>The Website may contain links to third-party websites or services not operated by Presto. If you click a third-party link, you will be directed to that third party's site. We strongly recommend reviewing the privacy policy of every website you visit. Presto has no control over and accepts no responsibility for the content, privacy policies, or practices of third-party sites.</p>

        <h2>Changes to This Privacy Policy</h2>
        <p>We may update this Privacy Policy from time to time. We will notify you of material changes by posting the updated Policy on this page and, where required, by sending an email notification prior to the change taking effect.</p>
        <p>The "Effective Date" at the top of this page reflects when the Policy was last updated. We encourage you to review this Policy periodically. Continued use of the Service after changes are posted constitutes acceptance of the updated Policy.</p>

        <h2>Contact Us</h2>
        <p>If you have any questions or concerns about this Privacy Policy or how Presto handles your personal data, please contact us:</p>
        <p><strong>Email:</strong> <a href="mailto:hello@heypresto.design">hello@heypresto.design</a><br>
        <strong>Website:</strong> <a href="/">https://heypresto.design</a></p>

        <p class="legal-footnote">Presto is a design and development subscription service based in Australia.</p>
      </div>
    </div>
  </main>

  <Footer
    tagline="Your brand's monthly creative partner. Design, WordPress, and direction — async, no lock-in."
    copyright="© 2026 Presto. Australia-based, globally trusted."
    columns={footerColumns}
  />
</Base>

<style>
  .legal-page {
    background: var(--bg);
    padding-bottom: var(--space-24);
  }

  .legal-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--space-8);
  }

  .legal-header {
    padding-top: var(--space-16);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-10);
  }

  .legal-header h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-4xl);
    line-height: 1.06;
    letter-spacing: -0.01em;
    color: var(--fg-1);
    margin: 0 0 var(--space-3);
  }

  .legal-meta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-3);
    margin: 0;
  }

  .legal-body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--fg-1);
  }

  .legal-body p {
    margin: 0 0 1.25rem;
  }

  .legal-body h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    color: var(--fg-1);
    margin: 2.75rem 0 0.75rem;
    padding-top: 0.25rem;
    border-top: 1px solid var(--border);
  }

  .legal-body h3 {
    font-family: var(--font-sans);
    font-weight: var(--weight-semibold);
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    color: var(--fg-1);
    margin: 1.75rem 0 0.5rem;
  }

  .legal-body ul,
  .legal-body ol {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .legal-body li {
    margin-bottom: 0.4rem;
  }

  .legal-body a {
    color: var(--purple-500);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-body a:hover {
    color: var(--purple-700);
  }

  .legal-footnote {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--fg-3);
    font-size: var(--text-sm);
  }

  @media (max-width: 600px) {
    .legal-header h1 {
      font-size: var(--text-3xl);
    }

    .legal-body h2 {
      font-size: var(--text-xl);
    }
  }
</style>

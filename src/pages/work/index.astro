---
import { getEntry, getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const page = await getEntry('work', 'work');
const d = page.data;

const allStudies = (await getCollection('caseStudies')).sort((a, b) => a.data.order - b.data.order);
const featured = allStudies.find(s => s.data.featured) ?? allStudies[0];
const rest = allStudies.filter(s => s.id !== featured.id);

const navLinks = [
  { label: 'How it works', href: '/#how-it-works' },
  { label: "What's included", href: '/#whats-included' },
  { label: 'Work', href: '/work/' },
  { label: 'Pricing', href: '/#pricing' },
  { label: 'FAQ', href: '/#faq' },
];

const footerColumns = [
  {
    heading: 'Product',
    links: [
      { label: 'How it works', href: '/#how-it-works' },
      { label: "What's included", href: '/#whats-included' },
      { label: 'Work', href: '/work/' },
      { label: 'Pricing', href: '/#pricing' },
      { label: 'FAQ', href: '/#faq' },
      { label: 'Free design report', href: '/the-reveal/' },
    ],
  },
  {
    heading: 'Socials',
    links: [
      { label: 'Facebook', href: 'https://www.facebook.com/heyprestodesign/' },
      { label: 'X', href: 'https://x.com/heyprestodesgn' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/company/heyprestodesign/' },
      { label: 'Instagram', href: 'https://www.instagram.com/heyprestodesgn' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Terms & Conditions', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Pause / Cancel', href: "mailto:hello@heypresto.design?subject=I'd%20like%20to%20pause%2Fcancel%2C%20effective%20at%20my%20next%20billing%20after%2030%20days" },
    ],
  },
];
---

<Base title={d.seo.title} description={d.seo.description}>
  <Header navLinks={navLinks} ctaLabel="Get started" ctaHref="/#pricing" />

  <main>
    <section class="work-hero">
      <img class="work-hero-burst" src="/assets/burst-cluster-purple.png" alt="" aria-hidden="true">
      <div class="wrap">
        <span class="eyebrow reveal"><span class="dot" aria-hidden="true"></span>{d.hero.eyebrow}</span>
        <h1 class="t-h1 work-hero-headline reveal reveal-delay-1">{d.hero.headline}</h1>
        <p class="work-hero-sub reveal reveal-delay-2">{d.hero.subline}</p>
        <div class="work-stats reveal reveal-delay-3">
          {d.hero.stats.map((stat, i) => (
            <>
              {i > 0 && <div class="work-stats-divider" aria-hidden="true"></div>}
              <div class="work-stat">
                <div class="work-stat-value">{stat.value}</div>
                <div class="work-stat-label">{stat.label}</div>
              </div>
            </>
          ))}
        </div>
      </div>
    </section>

    <section class="work-featured-wrap">
      <div class="wrap">
        <a href={`/work/${featured.id}/`} class="work-featured reveal">
          <div class="work-featured-copy">
            <span class="eyebrow">Featured project</span>
            <div class="work-card-category">{featured.data.category}</div>
            <h2 class="t-h2 work-featured-title">{featured.data.title}</h2>
            <p class="work-featured-desc">{featured.data.tagline}</p>
            {featured.data.cardTags && featured.data.cardTags.length > 0 && (
              <div class="work-featured-tags">
                {featured.data.cardTags.map(tag => <span class="work-tag">{tag}</span>)}
              </div>
            )}
            <div class="work-view-link work-view-link--circle">
              View case study
              <span class="work-view-arrow work-view-arrow--circle" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </div>
          </div>
          <div class="work-featured-media">
            <img src={featured.data.cardImage} alt={featured.data.cardImageAlt} loading="eager">
          </div>
        </a>
      </div>
    </section>

    <section class="work-grid-wrap">
      <div class="wrap">
        <div class="work-grid">
          {rest.map((study, i) => (
            <a href={`/work/${study.id}/`} class={`work-card reveal reveal-delay-${Math.min(i + 1, 3)}`}>
              <div class="work-card-media">
                <img src={study.data.cardImage} alt={study.data.cardImageAlt} loading="lazy">
              </div>
              <div class="work-card-body">
                <div class="work-card-category">{study.data.category}</div>
                <h3 class="work-card-title">{study.data.title}</h3>
                <p class="work-card-desc">{study.data.tagline}</p>
                <div class="work-view-link">
                  View case study
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer
    tagline="Your brand's monthly creative partner. Design, WordPress, and direction — async, no lock-in."
    copyright="© 2026 Presto. Australia-based, globally trusted."
    columns={footerColumns}
  />
</Base>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
  .work-hero { background: var(--cream); position: relative; overflow: hidden; }
  .work-hero-burst {
    position: absolute; right: -60px; top: -40px; width: 280px;
    opacity: .5; pointer-events: none; object-fit: contain;
  }
  .work-hero .wrap { padding: 96px 32px 88px; position: relative; }
  .work-hero-headline {
    margin: 22px 0 0;
    max-width: 15ch;
    text-wrap: balance;
  }
  .work-hero-sub {
    font-size: 20px;
    line-height: 1.6;
    color: var(--fg-2);
    margin: 24px 0 0;
    max-width: 56ch;
  }
  .work-stats { display: flex; gap: 28px; margin-top: 40px; flex-wrap: wrap; }
  .work-stats-divider { width: 1px; background: var(--border-strong); }
  .work-stat-value {
    font-family: var(--font-display); font-weight: var(--weight-bold);
    font-size: 40px; color: var(--navy-800); line-height: 1;
  }
  .work-stat-label { font-size: 14px; color: var(--fg-3); margin-top: 4px; }

  .work-featured-wrap { padding: 80px 0 24px; }
  .work-featured {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: #fff;
    box-shadow: var(--shadow-sm);
    transition: box-shadow .18s ease, transform .18s ease;
  }
  .work-featured:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
  .work-featured-copy { min-width: 0; padding: 52px 48px; display: flex; flex-direction: column; justify-content: center; }
  .work-featured-copy .eyebrow { margin-bottom: 20px; }
  .work-card-category {
    font-size: 13px; font-weight: 600; color: var(--fg-3);
    text-transform: uppercase; letter-spacing: .06em; margin-bottom: 12px;
  }
  .work-featured-title { margin: 0; }
  .work-featured-desc { font-size: 18px; line-height: 1.6; color: var(--fg-2); margin: 18px 0 0; }
  .work-featured-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 26px; }
  .work-tag {
    font-size: 12.5px; font-weight: 600; color: var(--fg-2);
    background: var(--navy-50); border: 1px solid var(--border);
    padding: 6px 13px; border-radius: 999px;
  }
  .work-featured-media { position: relative; min-width: 0; min-height: 440px; background: var(--navy-50); }
  .work-featured-media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .work-view-link {
    display: inline-flex; align-items: center; gap: 9px;
    font-weight: 600; font-size: 15.5px; color: var(--navy-800);
  }
  .work-card .work-view-link { margin-top: 20px; font-size: 14.5px; color: var(--purple-500); gap: 8px; }
  .work-view-link--circle { margin-top: 32px; }
  .work-view-arrow--circle {
    width: 26px; height: 26px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--purple-500); color: #fff;
  }

  .work-grid-wrap { padding: 32px 0 96px; }
  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
  }
  .work-card {
    display: flex; flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #fff;
    box-shadow: var(--shadow-sm);
    transition: box-shadow .18s ease, transform .18s ease;
  }
  .work-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
  .work-card-media { position: relative; height: 230px; background: var(--navy-50); }
  .work-card-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .work-card-body { padding: 26px 26px 30px; }
  .work-card-title {
    font-family: var(--font-display); font-weight: var(--weight-bold);
    font-size: 26px; line-height: 1.1; letter-spacing: -.01em; color: var(--navy-800); margin: 0;
  }
  .work-card-desc { font-size: 15.5px; line-height: 1.55; color: var(--fg-2); margin: 12px 0 0; }

  @media (max-width: 860px) {
    .work-featured { grid-template-columns: 1fr; }
    .work-featured-media { min-height: 280px; }
  }
  @media (max-width: 640px) {
    .work-hero .wrap { padding: 64px 20px 56px; }
    .work-featured-wrap { padding: 56px 0 16px; }
    .work-featured-copy { padding: 36px 28px; }
    .work-grid-wrap { padding: 24px 0 64px; }
  }
</style>

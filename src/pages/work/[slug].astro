---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const studies = (await getCollection('caseStudies')).sort((a, b) => a.data.order - b.data.order);
  return studies.map((entry, i) => {
    const prev = studies[(i - 1 + studies.length) % studies.length];
    const next = studies[(i + 1) % studies.length];
    return {
      params: { slug: entry.id },
      props: { entry, prev, next },
    };
  });
}

const { entry, prev, next } = Astro.props;
const d = entry.data;

const gallery = d.gallery ?? [];
const [g1, g2, g3, ...moreGallery] = gallery;

const navLinks = [
  { label: 'How it works', href: '/#how-it-works' },
  { label: "What's included", href: '/#whats-included' },
  { label: 'Work', href: '/work/' },
  { label: 'Pricing', href: '/#pricing' },
  { label: 'FAQ', href: '/#faq' },
];

const footerColumns = [
  {
    heading: 'Product',
    links: [
      { label: 'How it works', href: '/#how-it-works' },
      { label: "What's included", href: '/#whats-included' },
      { label: 'Work', href: '/work/' },
      { label: 'Pricing', href: '/#pricing' },
      { label: 'FAQ', href: '/#faq' },
      { label: 'Free design report', href: '/the-reveal/' },
    ],
  },
  {
    heading: 'Socials',
    links: [
      { label: 'Facebook', href: 'https://www.facebook.com/heyprestodesign/' },
      { label: 'X', href: 'https://x.com/heyprestodesgn' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/company/heyprestodesign/' },
      { label: 'Instagram', href: 'https://www.instagram.com/heyprestodesgn' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Terms & Conditions', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Pause / Cancel', href: "mailto:hello@heypresto.design?subject=I'd%20like%20to%20pause%2Fcancel%2C%20effective%20at%20my%20next%20billing%20after%2030%20days" },
    ],
  },
];
---

<Base title={d.seo.title} description={d.seo.description}>
  <Header navLinks={navLinks} ctaLabel="Get started" ctaHref="/#pricing" />

  <main>
    <div class="cs-wrap cs-crumb-wrap">
      <a href="/work/" class="cs-crumb">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
        All work
      </a>
    </div>

    <section class="cs-wrap cs-hero-copy">
      <span class="eyebrow reveal"><span class="dot" aria-hidden="true"></span>{d.category}</span>
      <h1 class="t-h1 cs-title reveal reveal-delay-1">{d.title}</h1>
      <p class="cs-tagline reveal reveal-delay-2">{d.tagline}</p>
    </section>

    <section class="cs-wrap cs-hero-image-wrap reveal reveal-delay-2">
      <div class="cs-hero-image">
        <img src={d.heroImage} alt={d.heroImageAlt} loading="eager">
      </div>
    </section>

    <section class="cs-wrap cs-brief-wrap">
      <div class="cs-brief-grid">
        <div class="reveal">
          <div class="cs-section-heading">The brief</div>
          <p class="cs-brief-text">{d.description}</p>
        </div>
        <aside class="cs-aside reveal reveal-delay-1">
          <div class="cs-aside-label">Deliverables</div>
          <div class="cs-deliverables">
            {d.deliverables.map(item => (
              <div class="cs-deliverable">
                <img src="/assets/burst-purple.png" alt="" aria-hidden="true">
                <span>{item}</span>
              </div>
            ))}
          </div>
          <div class="cs-turnaround">
            <div class="cs-aside-label cs-aside-label--muted">Turnaround</div>
            <div class="cs-turnaround-value">{d.turnaround}</div>
          </div>
        </aside>
      </div>
    </section>

    {gallery.length > 0 && (
      <section class="cs-wrap cs-gallery-wrap">
        <div class="cs-section-heading reveal">Selected work</div>
        <div class="cs-gallery">
          {g1 && (
            <div class="cs-gallery-large reveal">
              <img src={g1.image} alt={g1.alt} loading="lazy">
            </div>
          )}
          {g2 && (
            <div class="cs-gallery-item reveal reveal-delay-1">
              <img src={g2.image} alt={g2.alt} loading="lazy">
            </div>
          )}
          {g3 && (
            <div class="cs-gallery-item reveal reveal-delay-2">
              <img src={g3.image} alt={g3.alt} loading="lazy">
            </div>
          )}
        </div>
        {moreGallery.length > 0 && (
          <div class="cs-gallery-more">
            {moreGallery.map(img => (
              <div class="cs-gallery-more-item reveal">
                <img src={img.image} alt={img.alt} loading="lazy">
              </div>
            ))}
          </div>
        )}
      </section>
    )}

    <section class="cs-wrap cs-nav-wrap">
      <div class="cs-nav-grid">
        <a href={`/work/${prev.id}/`} class="cs-nav-card cs-nav-card--prev">
          <span class="cs-nav-label">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
            Previous
          </span>
          <span class="cs-nav-title">{prev.data.title}</span>
        </a>
        <a href={`/work/${next.id}/`} class="cs-nav-card cs-nav-card--next">
          <span class="cs-nav-label">
            Next
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
          <span class="cs-nav-title">{next.data.title}</span>
        </a>
      </div>
    </section>

    <section class="cs-wrap cs-cta-wrap">
      <div class="cs-cta reveal">
        <img class="cs-cta-burst cs-cta-burst--left" src="/assets/burst-cluster-white.png" alt="" aria-hidden="true">
        <img class="cs-cta-burst cs-cta-burst--right" src="/assets/burst-cluster-purple.png" alt="" aria-hidden="true">
        <div class="cs-cta-inner">
          <span class="eyebrow eyebrow--dark"><span class="dot" aria-hidden="true"></span>Your project next</span>
          <h2 class="t-h2 cs-cta-headline">Let's build something amazing. Together.</h2>
          <p class="cs-cta-sub">Submit a request and we take it from here. Senior brand, web, and strategy — async, on a monthly subscription.</p>
          <div class="cs-cta-actions">
            <a href="/#pricing" class="btn btn--lime btn--lg">
              Start a project
              <span class="btn-arrow" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </a>
            <a href="#" class="btn btn--ghost-light btn--lg" onclick="Calendly.initPopupWidget({url:'https://calendly.com/hello-heypresto/30min?text_color=0e0f52&primary_color=b301ff'});return false;">Book a call</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer
    tagline="Your brand's monthly creative partner. Design, WordPress, and direction — async, no lock-in."
    copyright="© 2026 Presto. Australia-based, globally trusted."
    columns={footerColumns}
  />
</Base>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
  .cs-wrap { max-width: 1120px; margin: 0 auto; padding: 0 28px; }

  .cs-crumb-wrap { padding: 36px 28px 0; }
  .cs-crumb {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14.5px; font-weight: 600; color: var(--fg-2);
    transition: color .15s;
  }
  .cs-crumb:hover { color: var(--purple-500); }

  .cs-hero-copy { padding: 28px 28px 8px; }
  .cs-title { margin: 20px 0 0; max-width: 16ch; text-wrap: balance; }
  .cs-tagline { font-size: 21px; line-height: 1.55; color: var(--fg-2); margin: 22px 0 0; max-width: 62ch; }

  .cs-hero-image-wrap { padding: 36px 28px 0; }
  .cs-hero-image {
    position: relative; border-radius: var(--radius-xl); overflow: hidden;
    background: var(--navy-50); height: 560px; border: 1px solid var(--border);
  }
  .cs-hero-image img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .cs-section-heading {
    font-family: var(--font-display); font-weight: var(--weight-bold);
    font-size: 30px; letter-spacing: -.01em; color: var(--navy-800);
  }

  .cs-brief-wrap { padding: 80px 28px 0; }
  .cs-brief-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 72px; align-items: start; }
  .cs-brief-text { font-size: 19px; line-height: 1.7; color: var(--fg-1); margin: 20px 0 0; }
  .cs-aside {
    border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 30px 30px 34px; background: var(--navy-50);
  }
  .cs-aside-label {
    font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--purple-500); margin-bottom: 18px;
  }
  .cs-aside-label--muted { color: var(--fg-3); margin-bottom: 6px; }
  .cs-deliverables { display: flex; flex-direction: column; }
  .cs-deliverable {
    display: flex; align-items: center; gap: 12px; padding: 13px 0;
    border-top: 1px solid var(--border);
  }
  .cs-deliverable:first-child { border-top: none; }
  .cs-deliverable img { width: 16px; height: 16px; flex: none; }
  .cs-deliverable span { font-size: 16px; font-weight: 600; color: var(--navy-800); }
  .cs-turnaround { margin-top: 24px; padding-top: 22px; border-top: 1px solid var(--border); }
  .cs-turnaround-value {
    font-family: var(--font-display); font-weight: var(--weight-bold);
    font-size: 22px; color: var(--navy-800);
  }

  .cs-gallery-wrap { padding: 80px 28px 0; }
  .cs-gallery-wrap .cs-section-heading { margin-bottom: 28px; }
  .cs-gallery {
    display: grid; grid-template-columns: 2fr 1fr; grid-auto-rows: 300px; gap: 20px;
  }
  .cs-gallery-large, .cs-gallery-item {
    position: relative; border-radius: var(--radius-lg); overflow: hidden;
    background: var(--navy-50); border: 1px solid var(--border);
  }
  .cs-gallery-large { grid-row: span 2; }
  .cs-gallery-large img, .cs-gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cs-gallery-more {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 20px;
  }
  .cs-gallery-more-item {
    position: relative; aspect-ratio: 4 / 3; border-radius: var(--radius-lg); overflow: hidden;
    background: var(--navy-50); border: 1px solid var(--border);
  }
  .cs-gallery-more-item img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .cs-nav-wrap { padding: 72px 28px 0; }
  .cs-nav-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .cs-nav-card {
    display: flex; flex-direction: column; gap: 8px; padding: 28px 30px;
    border: 1px solid var(--border); border-radius: var(--radius-lg);
    background: #fff; box-shadow: var(--shadow-sm);
    transition: box-shadow .18s ease, transform .18s ease;
  }
  .cs-nav-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .cs-nav-card--next { align-items: flex-end; text-align: right; }
  .cs-nav-label {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--fg-3);
  }
  .cs-nav-title {
    font-family: var(--font-display); font-weight: var(--weight-bold);
    font-size: 26px; letter-spacing: -.01em; color: var(--navy-800);
  }

  .cs-cta-wrap { padding: 88px 28px 96px; }
  .cs-cta {
    position: relative; overflow: hidden; background: var(--navy-800);
    border-radius: var(--radius-xl); padding: 72px 56px; text-align: center;
  }
  .cs-cta-burst { position: absolute; pointer-events: none; object-fit: contain; }
  .cs-cta-burst--left { left: -40px; bottom: -50px; width: 220px; opacity: .22; }
  .cs-cta-burst--right { right: -30px; top: -40px; width: 200px; opacity: .55; }
  .cs-cta-inner { position: relative; }
  .cs-cta-headline {
    color: #fff; margin: 20px auto 0; max-width: 18ch;
    font-size: clamp(32px, 5vw, 52px); line-height: 1.04;
  }
  .cs-cta-sub {
    font-size: 18.5px; line-height: 1.6; color: rgba(255,255,255,.72);
    margin: 20px auto 0; max-width: 52ch;
  }
  .cs-cta-actions { display: flex; gap: 14px; justify-content: center; margin-top: 34px; flex-wrap: wrap; }

  @media (max-width: 860px) {
    .cs-brief-grid { grid-template-columns: 1fr; gap: 32px; }
    .cs-gallery { grid-template-columns: 1fr; grid-auto-rows: 260px; }
    .cs-gallery-large { grid-row: span 1; }
  }
  @media (max-width: 640px) {
    .cs-hero-image { height: 320px; }
    .cs-brief-wrap, .cs-gallery-wrap, .cs-nav-wrap { padding-left: 20px; padding-right: 20px; padding-top: 56px; }
    .cs-cta-wrap { padding: 56px 20px 64px; }
    .cs-cta { padding: 48px 28px; }
    .cs-nav-grid { grid-template-columns: 1fr; }
    .cs-nav-card--next { align-items: flex-start; text-align: left; }
  }
</style>

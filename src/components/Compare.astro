---
interface Row {
  label: string;
  presto: string;
  agency: string;
  freelancer: string;
  inhouse: string;
}

interface Props {
  eyebrow: string;
  heading: string;
  rows: Row[];
}

const { eyebrow, heading, rows } = Astro.props;

const CheckHero = () => `<span class="cell-check--hero" aria-label="Yes"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>`;
const CheckPlain = () => `<span class="cell-check" aria-label="Yes"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>`;
const Cross = () => `<span class="cell-cross" aria-label="No"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg></span>`;

function renderCell(val: string, isPresto = false) {
  if (val === 'yes') return isPresto ? CheckHero() : CheckPlain();
  if (val === 'yes-plain') return CheckPlain();
  if (val === 'no') return Cross();
  return `<span class="cell-text">${val}</span>`;
}
---

<section class="compare" id="compare" aria-labelledby="compare-heading">
  <div class="wrap">
    <div style="max-width:640px;">
      <span class="eyebrow reveal"><span class="dot" aria-hidden="true"></span>{eyebrow}</span>
      <h2 class="t-h2 reveal reveal-delay-1" id="compare-heading" style="margin-top:18px;">{heading}</h2>
    </div>
    <div class="compare-table-wrap reveal reveal-delay-2">
      <table class="compare-table" aria-label="Presto vs alternatives">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col" class="col-presto">Presto</th>
            <th scope="col">Agency</th>
            <th scope="col">Freelancer</th>
            <th scope="col">In-house</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(row => (
            <tr>
              <td>{row.label}</td>
              <td class="col-presto" set:html={renderCell(row.presto, true)}></td>
              <td set:html={renderCell(row.agency)}></td>
              <td set:html={renderCell(row.freelancer)}></td>
              <td set:html={renderCell(row.inhouse)}></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

---
interface Props {
  eyebrow: string;
  heading: string;
  subline: string;
  cta: { label: string; href: string };
  rowA: string[];
  rowB: string[];
}

const { eyebrow, heading, subline, cta, rowA, rowB } = Astro.props;

const doubledA = [...rowA, ...rowA];
const doubledB = [...rowB, ...rowB];
---

<section class="portfolio" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="portfolio-header">
    <div style="max-width:680px;">
      <span class="eyebrow reveal"><span class="dot" aria-hidden="true"></span>{eyebrow}</span>
      <h2 class="t-h2 reveal reveal-delay-1" id="portfolio-heading" style="margin-top:18px;">{heading}</h2>
    </div>
    <div class="portfolio-header-right reveal reveal-delay-2">
      <a href={cta.href} class="btn btn--accent btn--sm">
        {cta.label}
        <span class="btn-arrow" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </span>
      </a>
      <p class="portfolio-sub">{subline}</p>
    </div>
  </div>
  <div class="portfolio-marquee-wrap" aria-hidden="true">
    <div class="marquee-row">
      <div class="marquee-track marquee-track--fwd">
        {doubledA.map(slug => (
          <div class="portfolio-card">
            <img src={`/assets/portfolio/${slug}.jpg`} alt="">
          </div>
        ))}
      </div>
    </div>
    <div class="marquee-row">
      <div class="marquee-track marquee-track--rev">
        {doubledB.map(slug => (
          <div class="portfolio-card">
            <img src={`/assets/portfolio/${slug}.jpg`} alt="">
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

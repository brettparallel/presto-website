---
interface Props {
  eyebrow: string;
  headline: string;
  subline: string;
  cta: { label: string; href: string };
  image: string;
  imageAlt: string;
}

const { eyebrow, headline, subline, cta, image, imageAlt } = Astro.props;
---

<section class="reveal-promo" id="the-reveal" aria-labelledby="reveal-promo-heading">
  <img class="reveal-promo-burst" src="/assets/burst-cluster-purple.png" alt="" aria-hidden="true">
  <div class="wrap">
    <div class="reveal-promo-copy">
      <span class="eyebrow eyebrow--dark reveal"><span class="dot" aria-hidden="true"></span>{eyebrow}</span>
      <h2 class="reveal-promo-headline reveal reveal-delay-1" id="reveal-promo-heading">{headline}</h2>
      <p class="reveal-promo-sub reveal reveal-delay-2">{subline}</p>
      <div class="reveal-promo-actions reveal reveal-delay-3">
        <a href={cta.href} class="btn btn--lime btn--lg">
          {cta.label}
          <span class="btn-arrow" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </span>
        </a>
      </div>
    </div>

    <a class="reveal-promo-media reveal reveal-delay-2" href={cta.href} aria-label={cta.label}>
      <img src={image} alt={imageAlt} width="1709" height="608" loading="lazy">
    </a>
  </div>
</section>

<style>
  .reveal-promo {
    background: var(--navy-800);
    color: #fff;
    position: relative;
    overflow: hidden;
  }
  .reveal-promo .wrap {
    padding-top: 100px;
    padding-bottom: 100px;
    position: relative;
    text-align: center;
  }
  .reveal-promo-burst {
    position: absolute;
    pointer-events: none;
    object-fit: contain;
    right: -50px;
    top: -40px;
    width: 220px;
    height: 220px;
    opacity: .3;
  }
  .reveal-promo-copy {
    max-width: 720px;
    margin: 0 auto;
  }
  .reveal-promo .eyebrow { justify-content: center; }
  .reveal-promo-headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(30px, 4vw, 46px);
    line-height: 1.06;
    letter-spacing: -0.01em;
    color: #fff;
    margin: 18px auto 0;
    max-width: 640px;
  }
  .reveal-promo-sub {
    font-size: 18px;
    line-height: 1.55;
    color: rgba(255,255,255,.78);
    max-width: 560px;
    margin: 20px auto 0;
  }
  .reveal-promo-actions {
    margin-top: 32px;
    display: flex;
    justify-content: center;
  }
  .reveal-promo-media {
    display: block;
    margin: 52px auto 0;
    max-width: 940px;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.14);
    box-shadow: var(--shadow-lg);
    line-height: 0;
    transition: transform .25s ease;
  }
  .reveal-promo-media:hover { transform: translateY(-4px); }
  .reveal-promo-media img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 640px) {
    .reveal-promo .wrap { padding-top: 72px; padding-bottom: 72px; }
    .reveal-promo-media { margin-top: 40px; }
  }
</style>

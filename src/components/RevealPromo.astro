---
interface Props {
  eyebrow: string;
  headline: string;
  subline: string;
  cta: { label: string; href: string };
  image: string;
  imageAlt: string;
}

const { eyebrow, headline, subline, cta, image, imageAlt } = Astro.props;
---

<section class="reveal-promo" id="the-reveal" aria-labelledby="reveal-promo-heading">
  <div class="wrap">
    <div class="reveal-promo-card reveal">
      <a class="reveal-promo-media" href={cta.href} aria-label={cta.label}>
        <img src={image} alt={imageAlt} width="760" height="760" loading="lazy">
      </a>
      <div class="reveal-promo-copy">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span>{eyebrow}</span>
        <h2 class="reveal-promo-headline" id="reveal-promo-heading">{headline}</h2>
        <p class="reveal-promo-sub">{subline}</p>
        <div class="reveal-promo-actions">
          <a href={cta.href} class="btn btn--primary btn--md">
            {cta.label}
            <span class="btn-arrow" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal-promo { background: var(--white); }
  .reveal-promo .wrap { padding-top: 64px; padding-bottom: 64px; }

  .reveal-promo-card {
    display: flex;
    align-items: center;
    gap: 40px;
    max-width: 900px;
    margin: 0 auto;
  }

  .reveal-promo-media {
    flex: 0 0 auto;
    width: clamp(220px, 26vw, 280px);
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    line-height: 0;
    transition: transform .2s ease;
  }
  .reveal-promo-media:hover { transform: translateY(-3px); }
  .reveal-promo-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .reveal-promo-copy { flex: 1 1 auto; text-align: left; }
  .reveal-promo-headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 2.6vw, 30px);
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: var(--fg-1);
    margin: 14px 0 0;
    max-width: 460px;
  }
  .reveal-promo-sub {
    font-size: 16px;
    line-height: 1.55;
    color: var(--fg-2);
    max-width: 480px;
    margin: 12px 0 0;
  }
  .reveal-promo-actions { margin-top: 22px; }

  @media (max-width: 680px) {
    .reveal-promo .wrap { padding-top: 48px; padding-bottom: 48px; }
    .reveal-promo-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
    .reveal-promo-media {
      width: 100%;
      max-width: 320px;
      align-self: auto;
      aspect-ratio: 1 / 1;
    }
  }
</style>
